# Backend API base URL (proxied via Vite dev server)
VITE_API_URL=http://localhost:8080

# Grafana base URL for the monitoring dashboard iframe
# In production, set this to the public Grafana URL (e.g. https://grafana.example.com)
VITE_GRAFANA_URL=http://localhost:3000

# Port for the Vite dev server
PORT=5173
